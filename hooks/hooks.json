{
  "description": "shipyard pipeline hooks: install bundled workflow engines on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/install-workflows.sh\" 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
